# Required for production — the CRM endpoint leads POST to.
# Until set, /api/lead logs non-PII lead context and returns ok so the form works in dev.
CURBIO_CRM_WEBHOOK_URL=

# Optional — sent as `Authorization: Bearer <key>` if present.
CURBIO_CRM_API_KEY=

# Optional — Upstash Redis (Vercel Marketplace integration, installed with
# custom prefix "UPSTASH_REDIS_REST" — hence the doubled "REST" below; these
# are the two auto-provisioned vars for the read-write REST API, not the
# sibling _KV_URL/_REDIS_URL (different protocols) or _READ_ONLY_TOKEN).
# When set, every valid lead is durably persisted (LPUSH leads:v1, capped at
# 5000) BEFORE the visitor gets ok:true, and /api/lead gains a 5/min per-IP
# rate limit. Absent = dev mode: log-and-continue, no persistence, no rate limit.
UPSTASH_REDIS_REST_KV_REST_API_URL=
UPSTASH_REDIS_REST_KV_REST_API_TOKEN=
